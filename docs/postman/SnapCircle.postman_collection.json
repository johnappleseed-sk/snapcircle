{
  "info": {
    "name": "SnapCircle API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "user_id",
      "value": "1"
    },
    {
      "key": "post_id",
      "value": "1"
    },
    {
      "key": "comment_id",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/api/health"
      }
    },
    {
      "name": "Google Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Accept", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"access_token\": \"google_access_token_here\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{base_url}}/api/auth/google"
      }
    },
    {
      "name": "Facebook Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Accept", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"access_token\": \"facebook_access_token_here\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{base_url}}/api/auth/facebook"
      }
    },
    {
      "name": "Get Profile",
      "request": {
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
        "method": "GET",
        "url": "{{base_url}}/api/profile"
      }
    },
    {
      "name": "Update Profile",
      "request": {
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
        "method": "PUT",
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "name", "value": "SnapCircle User", "type": "text" },
            { "key": "bio", "value": "Updated bio", "type": "text" },
            { "key": "avatar", "type": "file", "src": [] }
          ]
        },
        "url": "{{base_url}}/api/profile"
      }
    },
    {
      "name": "List Users",
      "request": {
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
        "method": "GET",
        "url": "{{base_url}}/api/users?search="
      }
    },
    {
      "name": "Show User",
      "request": {
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
        "method": "GET",
        "url": "{{base_url}}/api/users/{{user_id}}"
      }
    },
    {
      "name": "Follow User",
      "request": {
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
        "method": "POST",
        "url": "{{base_url}}/api/users/{{user_id}}/follow"
      }
    },
    {
      "name": "Unfollow User",
      "request": {
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
        "method": "DELETE",
        "url": "{{base_url}}/api/users/{{user_id}}/follow"
      }
    },
    {
      "name": "List Posts",
      "request": {
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
        "method": "GET",
        "url": "{{base_url}}/api/posts?search="
      }
    },
    {
      "name": "Create Post",
      "request": {
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
        "method": "POST",
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "content", "value": "Hello SnapCircle", "type": "text" },
            { "key": "image", "type": "file", "src": [] }
          ]
        },
        "url": "{{base_url}}/api/posts"
      }
    },
    {
      "name": "Show Post",
      "request": {
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
        "method": "GET",
        "url": "{{base_url}}/api/posts/{{post_id}}"
      }
    },
    {
      "name": "Update Post",
      "request": {
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
        "method": "PUT",
        "body": {
          "mode": "formdata",
          "formdata": [{ "key": "content", "value": "Updated post", "type": "text" }]
        },
        "url": "{{base_url}}/api/posts/{{post_id}}"
      }
    },
    {
      "name": "Delete Post",
      "request": {
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
        "method": "DELETE",
        "url": "{{base_url}}/api/posts/{{post_id}}"
      }
    },
    {
      "name": "Like Post",
      "request": {
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
        "method": "POST",
        "url": "{{base_url}}/api/posts/{{post_id}}/like"
      }
    },
    {
      "name": "Unlike Post",
      "request": {
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
        "method": "DELETE",
        "url": "{{base_url}}/api/posts/{{post_id}}/like"
      }
    },
    {
      "name": "List Comments",
      "request": {
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
        "method": "GET",
        "url": "{{base_url}}/api/posts/{{post_id}}/comments"
      }
    },
    {
      "name": "Create Comment",
      "request": {
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
        "method": "POST",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"comment\": \"Nice post!\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{base_url}}/api/posts/{{post_id}}/comments"
      }
    },
    {
      "name": "Update Comment",
      "request": {
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
        "method": "PUT",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"comment\": \"Updated comment\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{base_url}}/api/comments/{{comment_id}}"
      }
    },
    {
      "name": "Delete Comment",
      "request": {
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
        "method": "DELETE",
        "url": "{{base_url}}/api/comments/{{comment_id}}"
      }
    }
  ]
}
